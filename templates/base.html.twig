<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        {# DEV-ONLY: pin explicit versions and add SRI hashes any time these are updated. #}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph@0.3.0/dist/idiomorph.iife.js"
                integrity="sha384-3lBhB3sFGkvLEvdXpnrHrWCQWLOoJI0Fvo3K8pnOiZdmFwMW7sS8JMDwnDZBmlr"
                crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload@0.2.0/+esm"
                type="module"
                integrity="sha384-placeholder-replace-with-real-hash-before-deploying"
                crossorigin="anonymous"></script>
        {% endif %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
